# -------------------------
# netwatchv7 .env template
# -------------------------
# Secrets and runtime options for Netwatch (v7)
# Edit values, then load with: export $(grep -v '^#' .env | xargs)
# Or use docker --env-file .env when running containers.
# -------------------------

# Signal settings (required for Signal alerts)
# SIGNAL_NUMBER: the Signal account phone number used by the gateway (E.164 format)
SIGNAL_NUMBER="+15551234567"

# SIGNAL_RECIPIENTS: comma-separated list of recipient phone numbers (E.164)
SIGNAL_RECIPIENTS="+15559876543,+15557654321"

# SIGNAL_REST_URL: URL of the local Signal REST gateway (signal-cli-rest)
# Default binds to localhost; do not expose publicly.
SIGNAL_REST_URL="http://127.0.0.1:8080/v1/messages"

# Optional: path to YAML config inside container or host (leave empty to use defaults)
NETWATCH_CONFIG_PATH=""

# Scan profile: quick | standard | deep
SCAN_PROFILE="standard"

# Subnets to scan (space-separated). Leave empty to auto-detect.
# Example: "192.168.1.0/24 10.0.0.0/24"
SUBNETS=""

# Batching and alerting
BATCH_WINDOW_SECONDS="30"
BATCH_MAX_ITEMS="12"
ALERT_COOLDOWN_SECONDS="3600"

# Quiet hours (24-hour clock). Non-critical alerts suppressed during this window.
QUIET_HOURS_START="23"
QUIET_HOURS_END="7"

# Concurrency for port probes (tune for your host resources)
CONCURRENCY="8"

# Runtime mode: "scan" (single run) or "signal-test"
NETWATCH_CMD="scan"

# Optional: override Docker image behavior or pass additional flags
# e.g., EXTRA_ARGS="--profile quick"
EXTRA_ARGS=""

# -------------------------
# Security notes (do not edit below)
# -------------------------
# - Keep this file readable only by the user running the container:
#     chmod 600 .env
# - Do not commit this file to git or other VCS.
# - Prefer Docker secrets or a secret manager for production.
# -------------------------
